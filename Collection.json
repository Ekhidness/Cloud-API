    {
      "name": "03_Upload_Files",
      "request": {
        "method": "POST",
        "header": [],
        "auth": {
          "type": "bearer",
          "bearer": {
            "key": "token",
            "value": "{{token}}",
            "type": "string"
          }
        },
        "description": "",
        "url": {
          "raw": "{{host}}/files",
          "protocol": "",
          "host": [
            "{{host}}"
          ],
          "path": [
            "files"
          ],
          "query": [],
          "variable": []
        },
        "body": {
          "mode": "formdata",
          "formdata": [
            {
              "key": "files",
              "disabled": false,
              "type": "file",
              "src": "test.pdf"
            }
          ]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "packages": {},
            "requests": {},
            "exec": [
              "const body = pm.response.json();",
              "console.log(\"Upload response:\", body);",
              "",
              "const successFile = body.find(f => f.success === true);",
              "if (successFile && successFile.file_id) {",
              "    pm.environment.set(\"file_id\", successFile.file_id);",
              "    console.log(\"Saved file_id:\", successFile.file_id);",
              "} else {",
              "    console.log(\"No success file found!\");",
              "}"
            ]
          }
        }
      ]
